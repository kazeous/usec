generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  staff
  admin
}

enum Game {
  valorant
  cs2
  lol
}

enum RegistrationMode {
  solo
  team
}

enum RegistrationStatus {
  pending
  approved
  rejected
}

enum TournamentFormat {
  single_elimination
  double_elimination
  round_robin
  swiss
}

enum TournamentStatus {
  draft
  registration
  seeded
  live
  complete
  archived
}

enum EntryStatus {
  confirmed
  withdrawn
  disqualified
}

enum MatchStatus {
  pending
  scheduled
  veto
  live
  complete
  disputed
}

enum BracketSide {
  winners
  losers
  finals
  round_robin
  swiss
}

enum MatchOutcome {
  winner
  loser
}

enum MatchSlot {
  team_a
  team_b
}

enum VetoStatus {
  pending
  active
  complete
  cancelled
}

enum VetoActionType {
  ban
  pick
  decider
}

enum DraftStatus {
  planned
  active
  complete
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         UserRole  @default(staff)
  sessions     Session[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  key       String
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}

model Tournament {
  id                   String            @id @default(cuid())
  title                String
  game                 Game
  format               TournamentFormat
  status               TournamentStatus  @default(draft)
  registrationOpen     Boolean           @default(false)
  registrationMessage  String?
  registrationClosesAt DateTime?
  startsAt             DateTime?
  lockBracketAt        DateTime?
  swissRounds          Int?
  currentRound         Int               @default(0)
  registrations        Registration[]
  entries              TournamentEntry[]
  matches              Match[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([status, startsAt])
}

model Registration {
  id              String               @id @default(cuid())
  tournamentId    String
  tournament      Tournament           @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  game            Game
  mode            RegistrationMode
  status          RegistrationStatus   @default(pending)
  teamName        String?
  captchaProvider String?
  reviewNote      String?
  reviewedAt      DateTime?
  resolvedTeamId  String?
  resolvedTeam    Team?                @relation(fields: [resolvedTeamId], references: [id], onDelete: SetNull)
  members         RegistrationMember[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([tournamentId, status, mode])
  @@index([resolvedTeamId])
}

model RegistrationMember {
  id             String       @id @default(cuid())
  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  fullName       String
  studentId      String
  universityName String
  email          String
  discord        String?
  isCaptain      Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@unique([registrationId, studentId])
  @@unique([registrationId, email])
  @@index([studentId])
  @@index([email])
}

model Team {
  id            String            @id @default(cuid())
  game          Game
  name          String
  players       Player[]
  registrations Registration[]
  entries       TournamentEntry[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([game, name])
}

model Player {
  id             String                  @id @default(cuid())
  teamId         String
  team           Team                    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  fullName       String
  studentId      String
  universityName String
  email          String
  discord        String?
  isCaptain      Boolean                 @default(false)
  entrySnapshots TournamentEntryPlayer[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@unique([teamId, studentId])
  @@index([studentId])
  @@index([email])
}

model TournamentEntry {
  id           String                  @id @default(cuid())
  tournamentId String
  tournament   Tournament              @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamId       String
  team         Team                    @relation(fields: [teamId], references: [id], onDelete: Restrict)
  displayName  String
  seed         Int?
  status       EntryStatus             @default(confirmed)
  players      TournamentEntryPlayer[]
  matchesAsA   Match[]                 @relation("MatchEntryA")
  matchesAsB   Match[]                 @relation("MatchEntryB")
  wins         Match[]                 @relation("MatchWinnerEntry")
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@unique([tournamentId, teamId])
  @@index([tournamentId, status, seed])
}

model TournamentEntryPlayer {
  id             String          @id @default(cuid())
  entryId        String
  entry          TournamentEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  playerId       String
  player         Player          @relation(fields: [playerId], references: [id], onDelete: Restrict)
  fullName       String
  studentId      String
  universityName String
  email          String
  discord        String?
  isCaptain      Boolean         @default(false)

  @@unique([entryId, playerId])
  @@index([studentId])
}

model Match {
  id            String           @id @default(cuid())
  tournamentId  String
  tournament    Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  round         Int
  position      Int
  bracket       BracketSide
  status        MatchStatus      @default(pending)
  bestOf        Int              @default(1)
  teamAEntryId  String?
  teamA         TournamentEntry? @relation("MatchEntryA", fields: [teamAEntryId], references: [id], onDelete: SetNull)
  teamBEntryId  String?
  teamB         TournamentEntry? @relation("MatchEntryB", fields: [teamBEntryId], references: [id], onDelete: SetNull)
  winnerEntryId String?
  winner        TournamentEntry? @relation("MatchWinnerEntry", fields: [winnerEntryId], references: [id], onDelete: SetNull)
  teamAScore    Int              @default(0)
  teamBScore    Int              @default(0)
  scheduledAt   DateTime?
  isBye         Boolean          @default(false)
  isResetFinal  Boolean          @default(false)
  feedsOut      MatchFeed[]      @relation("SourceMatch")
  feedsIn       MatchFeed[]      @relation("TargetMatch")
  vetoSession   VetoSession?
  championDraft ChampionDraft?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([tournamentId, bracket, round, position])
  @@index([tournamentId, status])
}

model MatchFeed {
  id            String       @id @default(cuid())
  sourceMatchId String
  sourceMatch   Match        @relation("SourceMatch", fields: [sourceMatchId], references: [id], onDelete: Cascade)
  outcome       MatchOutcome
  targetMatchId String
  targetMatch   Match        @relation("TargetMatch", fields: [targetMatchId], references: [id], onDelete: Cascade)
  targetSlot    MatchSlot

  @@unique([sourceMatchId, outcome])
  @@unique([targetMatchId, targetSlot])
}

model VetoSession {
  id        String       @id @default(cuid())
  matchId   String       @unique
  match     Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  game      Game
  status    VetoStatus   @default(pending)
  mapPool   Json
  actions   VetoAction[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model VetoAction {
  id           String         @id @default(cuid())
  sessionId    String
  session      VetoSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  actorEntryId String?
  action       VetoActionType
  mapName      String
  order        Int
  createdAt    DateTime       @default(now())

  @@unique([sessionId, order])
}

model ChampionDraft {
  id        String      @id @default(cuid())
  matchId   String      @unique
  match     Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  status    DraftStatus @default(planned)
  state     Json?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}
